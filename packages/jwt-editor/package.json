{
  "name": "@grokify/jwt-editor",
  "version": "0.1.0",
  "description": "A web component for decoding and inspecting JWT tokens - built with Lit Web Components",
  "type": "module",
  "main": "dist/jwt-editor.umd.js",
  "module": "dist/jwt-editor.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/jwt-editor.es.js",
      "require": "./dist/jwt-editor.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "jwt",
    "json-web-token",
    "decoder",
    "inspector",
    "web-component",
    "lit"
  ],
  "author": "John Wang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokify/web-tools.git",
    "directory": "packages/jwt-editor"
  }
}
